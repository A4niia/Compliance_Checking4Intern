PREFIX ait: <http://ait.ac.th/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

#Case B: Violating Student - Unpaid Tuition

ait:student_652222 a ait:Student ;
  ait:hasStudentType "Self-Support" ;
  ait:hasEnrollmentStatus "Enrolled" ;
  ait:hasFinancialObligation [
	  a ait:Obligation ;
	  ait:hasObligationType "TuitionFee" ;
	  ait:isPaid "false"^^xsd:boolean
  ] .